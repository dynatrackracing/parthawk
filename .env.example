# Database (for local development with Docker PostgreSQL)
DB_HOST=127.0.0.1
DB_USER=wms
DB_PASSWORD=wms_password
DB_NAME=dynatrack
DB_TEST_NAME=dynatrack_test

# For production, use DATABASE_URL instead
# DATABASE_URL=postgres://user:password@host:5432/dbname

# eBay Trading API Credentials
TRADING_API_DEV_NAME=your-dev-name
TRADING_API_APP_NAME=your-app-name
TRADING_API_CERT_NAME=your-cert-name
TRADING_API_TOKEN=your-auth-token

# eBay Browse API (OAuth)
FINDINGS_APP_NAME=your-app-id

# Firebase (for authentication)
FIREBASE_BASE_64=base64-encoded-firebase-service-account-json

# Anthropic (for part location research)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Development settings
NODE_ENV=development
DISABLE_AUTH=true  # Set to 'true' to bypass authentication in development

# Optional
PORT=9000
RUN_JOB_NOW=0  # Set to '1' to run cron job immediately on startup
ITEM_PROCESS_BATCH=700
